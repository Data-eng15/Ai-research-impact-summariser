# ─────────────────────────────────────────────────────────────────────────────
# Impact Lab — Environment Variables Template
# Copy this file to .env (never commit .env)
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (Required) ──────────────────────────────────────────────────────────
# Get free API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ── App Mode ─────────────────────────────────────────────────────────────────
# true  = author verification runs but never blocks access (demo/dev)
# false = author verification blocks non-authors from REF generation
DEMO_MODE=true

# ── CORS (comma-separated list of allowed frontend origins) ──────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Optional API keys (improve rate limits & reliability) ────────────────────
# Semantic Scholar: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# GitHub: https://github.com/settings/tokens (read:public_repo scope)
GITHUB_TOKEN=

# ── Authentication ────────────────────────────────────────────────────────────
# LinkedIn OAuth (only needed if LinkedIn sign-in is enabled)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_SECRET=your_jwt_signing_secret_here

# ── Embedding model ───────────────────────────────────────────────────────────
# Default: sentence-transformers/all-MiniLM-L6-v2 (384 dimensions)
# Falls back to deterministic hash embedding if model fails to load
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
